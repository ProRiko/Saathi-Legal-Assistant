# Production Environment Configuration Template
# Copy this to .env and fill in your actual values

# ===========================================
# 🤖 LLM PROVIDER CONFIGURATION
# ===========================================
MODEL_PROVIDER=claude

# Default Anthropic Claude Haiku (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-haiku-20241022

# Optional Google Gemini fallback
GEMINI_API_KEY=your_optional_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ===========================================  
# 🗄️ DATABASE CONFIGURATION (OPTIONAL)
# ===========================================
# For production logging and conversation history
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
DATABASE_NAME=saathi_legal

# ===========================================
# 🚀 PRODUCTION SETTINGS  
# ===========================================
RAILWAY_ENVIRONMENT_NAME=production
FLASK_ENV=production
DEBUG=False

# ===========================================
# 🛡️ SECURITY CONFIGURATION
# ===========================================
# Your production domain for CORS
ALLOWED_ORIGINS=https://your-app.railway.app

# Secret key for sessions (generate a random string)
SECRET_KEY=your-secret-key-here

# ===========================================
# ⚡ PERFORMANCE SETTINGS
# ===========================================
MAX_TOKENS=2048
TEMPERATURE=0.7
REQUEST_TIMEOUT=30

# ===========================================
# 📊 MONITORING (OPTIONAL)
# ===========================================
# For error tracking and analytics
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=INFO

# ===========================================
# 💡 USAGE INSTRUCTIONS
# ===========================================
# 1. Copy this file to .env 
# 2. Replace all placeholder values with your actual configuration
# 3. Never commit .env to version control
# 4. For Railway: Add these as environment variables in Railway dashboard
